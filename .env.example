REDIS_PORT=6381
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
AGENT_PORT=8091

DB_PASSWORD=delivery
MYSQL_ROOT_PASSWORD=root-delivery
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
AGENT_SHARED_SECRET=local-agent-secret
# 用于加密数据库中的 API Token；生产环境必须使用独立、稳定的高强度值
