# OpenAI-compatible API (optional; core workflows remain usable when blank)
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=

# 私有化 Outline 文档中心
# collection-id 必须使用 Outline API 返回的集合 UUID，而不是浏览器地址中的 URL slug。
OUTLINE_BASE_URL=http://host.docker.internal:3000
OUTLINE_PUBLIC_BASE_URL=http://localhost:3000
OUTLINE_API_TOKEN=
OUTLINE_COLLECTION_ID=a4296a54-2044-4529-ba86-d598a5322e06
OUTLINE_STALE_AFTER=5m
